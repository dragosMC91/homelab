# Copy to .env and adjust values:
#   cp .env.example .env

# Host port mapped to AdGuard's DNS listener (port 53 inside container).
# Pi OS Lite:   use 53 (systemd-resolved is not active by default;
#               setup-pi.sh disables it if present).
# macOS dev:    use 5353 (mDNSResponder occupies 53).
HOST_DNS_PORT=53

# Bind address for the setup wizard (3000) and admin UI (8080).
# Defaults to 0.0.0.0 (all interfaces) so first-time setup works.
# After setup, lock it down:
#   - Tailscale only: set to your Tailscale IP (tailscale ip -4)
#   - Localhost only: set to 127.0.0.1 (access via SSH tunnel)
ADGUARD_BIND_IP=

TZ=Europe/Bucharest

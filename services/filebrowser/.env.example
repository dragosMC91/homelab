# Port for the FileBrowser web UI
FILEBROWSER_PORT=8082

# UID/GID to run as.
# Set PGID to the 'nasusers' group ID so FileBrowser can access all user
# directories without running as root. Find it with: getent group nasusers
# Then chmod 770 + chgrp nasusers each user's private folder under /mnt/nas-hdd/
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Bucharest

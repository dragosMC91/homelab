TZ=Europe/Bucharest
IMMICH_PORT=2283
IMMICH_VERSION=release

# Database — DB_PASSWORD has no default; compose will fail if .env is missing.
DB_DATABASE_NAME=immich
DB_USERNAME=immich
DB_PASSWORD=changeme

# Path to photo/video uploads.
# Default (./data/upload) is fine for testing. For a real library, point this
# at a larger volume — e.g. an external SSD or NFS mount from the RPi 5 NAS.
# UPLOAD_LOCATION=/Volumes/photos/immich

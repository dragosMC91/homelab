# Auth key from https://login.tailscale.com/admin/settings/keys
# Generate a reusable, ephemeral key for headless setup.
# Each node needs its own auth key (or reuse a single reusable key).
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX

# Hostname shown in the Tailscale admin console.
# MUST be unique per node:
#   pi-infra  — Raspberry Pi 3B+ (AdGuard + Tailscale)
#   nuc       — Intel NUC (Jellyfin + Uptime Kuma + Tailscale)
#   pi-nas    — Raspberry Pi 5 (NAS + Tailscale)
TS_HOSTNAME=homelab

# Exit node: Docker's nftables FORWARD policy (DROP) blocks Tailscale traffic.
# On the exit node host, make sure port forwarding is enabled 
# allow it through the DOCKER-USER chain:
#   sudo iptables -I DOCKER-USER -i tailscale0 -j ACCEPT
#   sudo iptables -I DOCKER-USER -o tailscale0 -j ACCEPT
# These rules are not persistent — re-apply after reboot or use iptables-persistent.
#
# On pi-infra, also advertise routes so remote devices can reach the LAN
# and also prevent Tailscale from overwriting the system DNS config.
# TS_EXTRA_ARGS=--advertise-exit-node --accept-dns=false

TS_USERSPACE=false

# Prevent Tailscale from overwriting the system DNS config.
# Set to false on pi-infra (runs AdGuard Home — must keep its own DNS).
# Set to true on other nodes if you want them to use Tailscale MagicDNS.
TS_ACCEPT_DNS=false
